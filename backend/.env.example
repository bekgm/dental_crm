# Application
APP_NAME=DentalCRM
APP_VERSION=1.0.0
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://dentalcrm:dentalcrm_secret@db:5432/dentalcrm

# JWT
SECRET_KEY=change-me-to-a-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Upload
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10

# Admin seed
ADMIN_EMAIL=admin@dentflow.com
ADMIN_PASSWORD=admin123
